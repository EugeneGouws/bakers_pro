# Baker's Cost Pro — environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# Apify API key (client-side — used for Checkers price scraping)
VITE_APIFY_KEY=

# GitHub repo in owner/repo format (client-side — used to build raw content URLs)
VITE_GITHUB_REPO=EugeneGouws/bakers_pro

# GitHub branch to read community data from (defaults to "main" if omitted)
VITE_GITHUB_BRANCH=main

# GitHub Personal Access Token with Contents:write on the repo
# Set this in the Netlify dashboard (and locally for testing Netlify functions)
VITE_GITHUB_TOKEN=
